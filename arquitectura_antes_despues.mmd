flowchart TD
    %% Estilos
    classDef antes fill:#ffe6e6,stroke:#ff4d4d,stroke-width:2px,color:#333;
    classDef despues fill:#e6f9ec,stroke:#28a745,stroke-width:2px,color:#333;
    classDef aws fill:#ff9900,color:black,stroke:#333,stroke-width:1px;
    classDef db fill:#0052cc,color:white,stroke:#003d99,stroke-width:1px;
    classDef stream fill:#ff4b4b,color:white,stroke:#cc0000,stroke-width:1px;
    classDef process fill:#f9f9f9,stroke:#666,stroke-width:1px,color:#333;

    subgraph ANTES ["🔴 ANTES: Desorganización y Manualidad"]
        direction LR
        E1["Archivos Excel<br>y Notas Físicas"]:::antes --> M1["Consolidación<br>Manual"]:::antes
        M1 --> R1["Reportes Lentos<br>y Propensos a Errores"]:::antes
        R1 --> D1["Falta de Visibilidad<br>de Rentabilidad"]:::antes
    end

    subgraph DESPUES ["🟢 DESPUÉS: Pipeline de Datos Moderno (Arquitectura Medallón)"]
        direction TB
        
        subgraph EXTRACCION ["1. Ingesta (main_pipeline.py)"]
            Src[("Generador de<br>Transacciones")]:::db
        end
        
        subgraph LAKHOUSE ["2. Data Lakehouse"]
            direction LR
            Bz[("🥉 Bronze<br>Datos Crudos")]:::db
            Sv[("🥈 Silver<br>Datos Limpios")]:::db
            Gd[("🥇 Gold<br>Datamarts")]:::db
            
            Bz -->|"Limpieza y<br>Feature Engineering"| Sv
            Sv -->|"Reglas de Negocio<br>y Agrupaciones"| Gd
        end
        
        Src -->|"Extracción"| Bz
        
        subgraph CONSUMO ["3. Consumo"]
            St["Dashboard en Streamlit<br>(Tiempo Real)"]:::stream
            Gd -->|"Insights"| St
        end
    end

    subgraph NUBE ["☁️ Infraestructura Cloud & CI/CD"]
        direction LR
        GH["GitHub Actions"]:::process --> NUBE_SRV["AWS Fargate / GCP Cloud Run / Azure ACI"]:::aws
        NUBE_SRV -.-> |"Orquestación<br>Automatizada"| Src
    end

    %% Conexión visual para flujo
    D1 ~~~ GH
